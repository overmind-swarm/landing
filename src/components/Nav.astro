---
import { t, type Lang, languages, getAlternateUrl } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const appUrl = 'https://app.curiabots.com/login';
const homeBase = lang === 'en' ? '/' : `/${lang}/`;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangUrl = getAlternateUrl(Astro.url, otherLang as Lang);
---

<nav class="fixed top-0 w-full z-50 bg-black/80 backdrop-blur-xl border-b border-white/5" aria-label="Main navigation">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href={lang === 'en' ? '/' : `/${lang}/`} class="flex items-center gap-3 font-black text-2xl tracking-tighter">
      <div class="bg-gradient-to-tr from-blue-600 to-indigo-600 p-2 rounded-xl shadow-lg shadow-blue-500/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
      </div>
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-white to-white/60">
        {t(lang, 'common.appName')}
      </span>
    </a>
    <div class="flex items-center gap-10 text-xs font-bold tracking-widest uppercase text-gray-400">
      <a href={`${homeBase}#features`} class="hidden md:block hover:text-blue-400 transition-colors">{t(lang, 'nav.experience')}</a>
      <a href={`${homeBase}#vision`} class="hidden md:block hover:text-blue-400 transition-colors">{t(lang, 'nav.vision')}</a>
      <a href={otherLangUrl} class="hidden md:block hover:text-blue-400 transition-colors">{languages[otherLang]}</a>
      <a
        href={appUrl}
        class="hidden md:inline-block bg-white text-black px-8 py-3 rounded-full hover:bg-blue-500 hover:text-white transition-all duration-300 transform active:scale-95 shadow-xl shadow-white/5"
      >
        {t(lang, 'nav.logIn')}
      </a>
      <!-- Mobile hamburger button -->
      <button type="button" id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </div>
  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="hidden md:hidden bg-black/95 backdrop-blur-xl border-b border-white/5 px-6 pb-8 pt-4">
    <div class="flex flex-col gap-6 text-sm font-bold tracking-widest uppercase text-gray-400">
      <a href={`${homeBase}#features`} class="hover:text-blue-400 transition-colors mobile-nav-link">{t(lang, 'nav.experience')}</a>
      <a href={`${homeBase}#vision`} class="hover:text-blue-400 transition-colors mobile-nav-link">{t(lang, 'nav.vision')}</a>
      <a href={otherLangUrl} class="hover:text-blue-400 transition-colors">{languages[otherLang]}</a>
      <a
        href={appUrl}
        class="bg-white text-black px-8 py-3 rounded-full hover:bg-blue-500 hover:text-white transition-all duration-300 text-center shadow-xl shadow-white/5"
      >
        {t(lang, 'nav.logIn')}
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  if (menuBtn && mobileMenu && bar1 && bar2 && bar3) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      // Animate hamburger to X
      bar1.style.transform = isOpen ? '' : 'rotate(45deg) translate(4px, 4px)';
      bar2.style.opacity = isOpen ? '1' : '0';
      bar3.style.transform = isOpen ? '' : 'rotate(-45deg) translate(4px, -4px)';
    });

    // Close menu when clicking a nav link
    mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        bar1.style.transform = '';
        bar2.style.opacity = '1';
        bar3.style.transform = '';
      });
    });
  }
</script>
