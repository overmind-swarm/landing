---
import { t, type Lang } from '../i18n';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const appUrl = 'https://app.curiabots.com/login';
---

<Nav lang={lang} />

<!-- Hero Section -->
<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-ai.jpg"
      alt="AI Concept"
      width="2232"
      height="1256"
      class="w-full h-full object-cover opacity-50 scale-105"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black"></div>
    <div class="absolute inset-0 bg-blue-900/10 mix-blend-overlay"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-5xl">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-[10px] font-black tracking-[0.2em] uppercase text-blue-400 mb-10 reveal">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
      <span>{t(lang, 'hero.badge')}</span>
    </div>
    <h1 class="text-7xl md:text-[120px] font-black tracking-tighter mb-8 leading-[0.85] reveal delay-100">
      {t(lang, 'hero.titleLine1')} <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-500">{t(lang, 'hero.titleLine2')}</span>
    </h1>
    <p class="text-lg md:text-2xl text-gray-400 mb-12 max-w-2xl mx-auto font-medium leading-relaxed reveal delay-200">
      {t(lang, 'hero.subtitle')}
    </p>
    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center reveal delay-300">
      <a
        href={appUrl}
        class="group px-10 py-5 bg-blue-600 rounded-full font-black text-lg hover:bg-blue-500 transition-all transform hover:scale-105 flex items-center gap-3 shadow-2xl shadow-blue-600/20"
      >
        {t(lang, 'hero.cta')}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </div>

  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4">
    <span class="text-[10px] font-black tracking-[0.3em] uppercase text-white/30">{t(lang, 'hero.scroll')}</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-blue-500 to-transparent"></div>
  </div>
</section>

<!-- Feature Showcase -->
<section id="features" class="py-32 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Box 1: Agenda & Time -->
      <div class="md:col-span-8 h-[500px] reveal">
        <div class="relative w-full h-full rounded-3xl overflow-hidden border border-white/10 group">
          <div class="relative w-full h-full rounded-2xl overflow-hidden border border-white/10 bg-zinc-900">
            <img src="/images/agenda.jpg" alt={t(lang, 'features.agendaLabel')} width="2068" height="1382" class="w-full h-full object-cover opacity-60 group-hover:opacity-40 transition-opacity duration-700" loading="lazy" />
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
              <span class="text-xs font-bold tracking-widest uppercase text-white/60 group-hover:text-white transition-colors">{t(lang, 'features.agendaLabel')}</span>
            </div>
          </div>
          <div class="absolute top-8 left-8 p-6 bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl max-w-xs pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400 mb-4" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            <h3 class="text-2xl font-bold mb-2">{t(lang, 'features.totalControl')}</h3>
            <p class="text-sm text-white/60">{t(lang, 'features.totalControlDesc')}</p>
          </div>
        </div>
      </div>

      <!-- Box 2: Reminders -->
      <div class="md:col-span-4 h-[500px] reveal delay-200">
        <div class="relative w-full h-full rounded-3xl overflow-hidden border border-white/10 bg-gradient-to-br from-indigo-900/20 to-black p-8 flex flex-col justify-end">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-400 mb-6" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
          <h3 class="text-3xl font-bold mb-4">{t(lang, 'features.reminders')}</h3>
          <p class="text-gray-400 mb-8">{t(lang, 'features.remindersDesc')}</p>
          <div class="space-y-3">
            {[1, 2, 3].map((i) => (
              <div class="h-12 bg-white/5 border border-white/5 rounded-xl flex items-center px-4 gap-3 animate-pulse" style={`animation-delay: ${i * 200}ms`}>
                <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
                <div class="h-2 w-24 bg-white/20 rounded"></div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Box 3: Automation -->
      <div class="md:col-span-4 h-[600px] reveal">
        <div class="relative w-full h-full rounded-3xl overflow-hidden border border-white/10 group">
          <div class="relative w-full h-full rounded-2xl overflow-hidden border border-white/10 bg-zinc-900">
            <img src="/images/automation.jpg" alt={t(lang, 'features.automationLabel')} width="2070" height="1380" class="w-full h-full object-cover opacity-60 group-hover:opacity-40 transition-opacity duration-700" loading="lazy" />
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
              <span class="text-xs font-bold tracking-widest uppercase text-white/60 group-hover:text-white transition-colors">{t(lang, 'features.automationLabel')}</span>
            </div>
          </div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="p-6 bg-blue-600 rounded-2xl shadow-2xl">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
              <h4 class="font-bold text-lg italic">{t(lang, 'features.automationQuote')}</h4>
            </div>
          </div>
        </div>
      </div>

      <!-- Box 4: Life Order -->
      <div class="md:col-span-8 h-[600px] reveal delay-200">
        <div class="relative w-full h-full rounded-3xl overflow-hidden border border-white/10 bg-zinc-900 flex items-center justify-center">
          <img
            src="/images/life-order.jpg"
            class="absolute inset-0 w-full h-full object-cover opacity-20"
            alt="Life Order"
            width="2072"
            height="1379"
            loading="lazy"
          />
          <div class="relative z-10 text-center px-12">
            <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-8 text-blue-500" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            <h3 class="text-5xl font-black tracking-tighter mb-6">{t(lang, 'features.lifeOrder')}</h3>
            <p class="text-xl text-gray-400 max-w-lg mx-auto mb-10">
              {t(lang, 'features.lifeOrderDesc')}
            </p>
            <div class="flex gap-4 justify-center flex-wrap">
              <div class="px-6 py-3 rounded-full bg-white/5 border border-white/10 text-sm font-bold flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {t(lang, 'features.habits')}
              </div>
              <div class="px-6 py-3 rounded-full bg-white/5 border border-white/10 text-sm font-bold flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                {t(lang, 'features.goals')}
              </div>
              <div class="px-6 py-3 rounded-full bg-white/5 border border-white/10 text-sm font-bold flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                {t(lang, 'features.tasks')}
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Vision Section -->
<section id="vision" class="bg-white text-black py-32 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
      <div class="max-w-2xl">
        <h2 class="text-6xl md:text-8xl font-black tracking-tighter leading-none mb-8">{t(lang, 'vision.title')}</h2>
        <p class="text-xl font-medium text-black/60 italic">{t(lang, 'vision.subtitle')}</p>
      </div>
      <div class="text-right">
        <div class="text-4xl font-black mb-2">01 — 04</div>
        <div class="text-[10px] font-black tracking-[0.3em] uppercase text-black/40">{t(lang, 'vision.chapters')}</div>
      </div>
    </div>

    <div class="aspect-[21/9] w-full rounded-[40px] overflow-hidden bg-zinc-200 relative group shadow-2xl">
      <div class="relative w-full h-full rounded-2xl overflow-hidden border border-white/10 bg-zinc-900">
        <img src="/images/vision.jpg" alt={t(lang, 'vision.filmLabel')} width="2070" height="1382" class="w-full h-full object-cover opacity-60 group-hover:opacity-40 transition-opacity duration-700" loading="lazy" />
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
          <span class="text-xs font-bold tracking-widest uppercase text-black/60 group-hover:text-black transition-colors">{t(lang, 'vision.filmLabel')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Massive CTA -->
<section class="py-40 px-6 relative overflow-hidden">
  <div class="absolute inset-0 bg-blue-600 opacity-10 blur-[120px] rounded-full translate-y-1/2"></div>
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <h2 class="text-6xl md:text-9xl font-black tracking-tighter mb-12">{t(lang, 'cta.title')}</h2>
    <a
      href={appUrl}
      class="inline-block px-16 py-8 bg-white text-black rounded-full font-black text-2xl hover:bg-blue-600 hover:text-white transition-all transform hover:scale-105 shadow-2xl"
    >
      {t(lang, 'cta.button')}
    </a>
    <div class="mt-16 flex justify-center gap-12 text-white/40 font-black tracking-widest text-[10px] uppercase flex-wrap">
      <span>{t(lang, 'cta.earlyAccess')}</span>
      <span>&bull;</span>
      <span>{t(lang, 'cta.version')}</span>
      <span>&bull;</span>
      <span>{t(lang, 'cta.globalNetwork')}</span>
    </div>
  </div>
</section>

<Footer lang={lang} />

<!-- Scroll reveal script -->
<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(2.5rem);
    transition: opacity 1s ease, transform 1s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal.delay-100 { transition-delay: 100ms; }
  .reveal.delay-200 { transition-delay: 200ms; }
  .reveal.delay-300 { transition-delay: 300ms; }
</style>
