---
import { t, type Lang, defaultLang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const prefix = lang === defaultLang ? '' : `/${lang}`;
---

<footer class="py-12 border-t border-white/5 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
    <div class="flex items-center gap-2 font-black text-lg">
      <div class="w-2 h-2 rounded-full bg-blue-500 animate-pulse" aria-hidden="true"></div>
      {t(lang, 'common.appName')}
    </div>
    <div class="flex gap-10 text-[10px] font-black tracking-widest uppercase text-white/30">
      <a href={`${prefix}/privacy`} class="hover:text-white transition-colors">{t(lang, 'footer.privacy')}</a>
      <a href={`${prefix}/terms`} class="hover:text-white transition-colors">{t(lang, 'footer.terms')}</a>
      <a href={`mailto:contact@curiabots.com?subject=${encodeURIComponent(t(lang, 'footer.contact'))}`} class="hover:text-white transition-colors">{t(lang, 'footer.contact')}</a>
    </div>
    <div class="text-[10px] font-black tracking-widest uppercase text-white/10">
      {t(lang, 'footer.copyright')}
    </div>
  </div>
</footer>
